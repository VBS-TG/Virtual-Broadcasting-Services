{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vbs.local/schemas/telemetry.v1.schema.json",
  "title": "VBS Telemetry v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["node_id", "node_type", "ts_ms", "metrics"],
  "properties": {
    "node_id": {"type": "string", "minLength": 1},
    "node_type": {"type": "string", "enum": ["capture", "route", "engine", "console"]},
    "ts_ms": {"type": "integer", "minimum": 0},
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cpu_pct": {"type": "number", "minimum": 0, "maximum": 100},
        "mem_bytes": {"type": "integer", "minimum": 0},
        "ingest_mbps": {"type": "number", "minimum": 0},
        "reorder_error_pct": {"type": "number", "minimum": 0, "maximum": 100},
        "has_engine_client": {"type": "boolean"},
        "gpu_pct": {"type": "number", "minimum": 0, "maximum": 100},
        "vram_bytes": {"type": "integer", "minimum": 0},
        "stream_ok": {"type": "boolean"}
      }
    },
    "auth_mode": {"type": "string", "enum": ["bearer", "legacy_key"]}
  }
}
