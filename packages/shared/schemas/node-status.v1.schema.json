{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vbs.local/schemas/node-status.v1.schema.json",
  "title": "Node Status v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["node_id", "node_type", "status", "updated_at_ms"],
  "properties": {
    "node_id": {"type": "string", "minLength": 1},
    "node_type": {"type": "string", "enum": ["capture", "route", "engine", "console"]},
    "status": {"type": "string", "enum": ["starting", "ready", "degraded", "offline"]},
    "updated_at_ms": {"type": "integer", "minimum": 0},
    "reason": {"type": "string"}
  }
}
