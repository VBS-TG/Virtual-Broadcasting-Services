# 複製為 .env.engine 後填入（勿提交真實密鑰）
VBS_ENGINE_SRT_INPUT_1_URI=srt://your-route-host:20030?mode=caller&latency=2000&passphrase=YOUR_10_64_CHAR_SECRET&pbkeylen=32
VBS_ENGINE_SRT_INPUT_2_URI=srt://your-route-host:20030?mode=caller&latency=2000&passphrase=YOUR_10_64_CHAR_SECRET&pbkeylen=32
VBS_ENGINE_PGM_SRT_URI=srt://your-obs-or-receiver:9999?mode=caller&latency=2000&passphrase=YOUR_10_64_CHAR_SECRET&pbkeylen=32
VBS_ENGINE_MIXER_WIDTH=854
VBS_ENGINE_MIXER_HEIGHT=480

# WebRTC（Brave）
# VBS_ENGINE_STUN_SERVER=stun.l.google.com:19302
# VBS_ENGINE_TURN_SERVER=user:pass@turn.example.com:3478

# 遙測（可選；需 Console HTTPS 基底）
# VBS_CONSOLE_BASE_URL=https://api.example.com
# VBS_ENGINE_TELEMETRY_WS_PATH=/vbs/telemetry/ws
# VBS_NODE_ID=vbs-engine
# VBS_METRICS_INTERVAL=1000ms
# VBS_API_KEY=
# VBS_ENGINE_JWT=

# 進階
# VBS_ENGINE_REQUIRE_NVIDIA=1
# VBS_ENGINE_REQUIRE_GST_NVH265DEC=0
# VBS_ENGINE_MTU_IFACE=eth0
# VBS_ENGINE_MTU=1400
# VBS_ENGINE_RESTART_INITIAL_SEC=1
# VBS_ENGINE_RESTART_BACKOFF_MAX_SEC=30
