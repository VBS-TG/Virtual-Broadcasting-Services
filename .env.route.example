# 複製為 .env.route 後填入（勿提交真實密鑰）
VBS_CONSOLE_BASE_URL=http://your-console-host:4000
VBS_SRT_PASSPHRASE=YOUR_10_64_CHAR_SECRET

# 三擇一：預先發好的 JWT，或 Device 身分註冊，或 bootstrap token（相容舊流程）
# VBS_ROUTE_JWT=
VBS_ROUTE_DEVICE_ID=vbs-route-01
VBS_ROUTE_DEVICE_SECRET=YOUR_ROUTE_DEVICE_SECRET
VBS_ROUTE_BOOTSTRAP_TOKEN=YOUR_ROUTE_BOOTSTRAP_TOKEN

