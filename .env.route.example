# 複製為 .env.route 後填入（勿提交真實密鑰）
# 本機 Docker compose 預設對外 5000；Tunnel 則用 https://api.yourdomain.com
VBS_CONSOLE_BASE_URL=http://your-console-host:5000
VBS_SRT_PASSPHRASE=YOUR_10_64_CHAR_SECRET

# 四擇一：Cloudflare Access（正式版）、預先發好的 JWT、Device 註冊、bootstrap token（舊流程）
# Cloudflare Access（正式版建議）
VBS_CF_ACCESS_CLIENT_ID=ROUTE_CF_ACCESS_CLIENT_ID
VBS_CF_ACCESS_CLIENT_SECRET=ROUTE_CF_ACCESS_CLIENT_SECRET

# VBS_ROUTE_JWT=
VBS_ROUTE_DEVICE_ID=vbs-route-01
VBS_ROUTE_DEVICE_SECRET=YOUR_ROUTE_DEVICE_SECRET
VBS_ROUTE_BOOTSTRAP_TOKEN=YOUR_ROUTE_BOOTSTRAP_TOKEN

